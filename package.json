{
  "name": "tformula",
  "version": "0.1.0",
  "description": "Render LaTeX from any CLI agent in Kitty-compatible terminals.",
  "keywords": [
    "terminal",
    "latex",
    "mathjax",
    "kitty",
    "ghostty",
    "cli",
    "ai-agent"
  ],
  "homepage": "https://github.com/mikewang817/TFormula#readme",
  "bugs": {
    "url": "https://github.com/mikewang817/TFormula/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikewang817/TFormula.git"
  },
  "type": "module",
  "bin": {
    "tformula": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "@mathjax/mathjax-mhchem-font-extension": "^4.1.3",
    "@mathjax/src": "^4.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0",
    "string-width": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "node-pty": true
  }
}
