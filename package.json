{
  "name": "tformula",
  "version": "0.1.0",
  "description": "A terminal-agnostic PTY proxy that renders LaTeX from any CLI agent in Ghostty.",
  "type": "module",
  "bin": {
    "tformula": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "check": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mathjax/src": "^4.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0",
    "string-width": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "allowScripts": {}
}
